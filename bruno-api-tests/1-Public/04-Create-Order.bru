meta {
  name: 04. Create Order
  type: http
  seq: 4
}

post {
  url: {{base_url}}/api/orders
  body: json
  auth: bearer
}

headers {
  Accept: application/json
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "items": [
      {
              "product_id": "019ea6c0-3894-70fc-9260-60f63fa4a57f",
        "quantity": 10
      }
    ]
  }
}

script:post-response {
  if (res.status === 200 && res.body.data && res.body.data.orderId) {
    bru.setEnvVar("order_id", res.body.data.orderId);
  }
}

tests {
  test("Status is 200", function() {
    expect(res.status).to.equal(200);
  });
  test("Order is created", function() {
    expect(res.body.status).to.equal("success");
    expect(res.body.data.orderId).to.be.a('string');
  });
}
