meta {
  name: 03. Get Products
  type: http
  seq: 3
}
get {
  url: {{base_url}}/api/products
  body: none
  auth: none
headers {
  Accept: application/json
}
}
script:post-response {
  if (res.status === 200 && res.body.data && res.body.data.length > 0) {
    // Save the first product ID for ordering
    bru.setEnvVar("first_product_id", res.body.data[0].id);
  }
}
tests {
  test("Status is 200", function() {
    expect(res.status).to.equal(200);
  });
  test("Returns an array of products", function() {
    expect(res.body.data).to.be.an('array');
  });
}
