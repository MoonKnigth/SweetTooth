meta {
  name: Simulate Refund Webhook
  type: http
  seq: 2
}

post {
  url: {{base_url}}/api/webhooks/payment-center
  body: json
  auth: bearer
}

headers {
  X-Payment-Signature: {{hmac_signature}}
  Content-Type: application/json
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "reference": "REF-12345",
    "status": "refunded",
    "amount": 2800,
    "omise_charge_id": "chrg_test_refund_123"
  }
}

docs {
  จำลอง Payment Center ส่ง Webhook สถานะ 'refunded' กลับมายังระบบ SweetTooth
  X-Payment-Signature ต้องตรงกับค่า HMAC-SHA256 ที่ Gen ด้วย Payload นี้และ Webhook Secret
}
