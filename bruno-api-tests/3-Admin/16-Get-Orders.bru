meta {
  name: 16. Get Orders
  type: http
  seq: 16
}
get {
  url: {{base_url}}/api/admin/orders
  body: none
  auth: bearer
}
auth:bearer {
  token: {{token}}
}
headers {
  Accept: application/json
}
script:post-response {
  if (res.status === 200 && res.body.data && res.body.data.length > 0) {
    bru.setEnvVar("test_order_id", res.body.data[0].id);
  }
}
tests {
  test("Status is 200", function() {
    expect(res.status).to.equal(200);
  });
}
