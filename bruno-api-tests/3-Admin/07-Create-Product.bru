meta {
  name: 06. Create Product (Admin)
  type: http
  seq: 6
}
post {
  url: {{base_url}}/api/admin/products
  body: json
  auth: bearer
}
auth:bearer {
  token: {{token}}
}
body:json {
  {
    "name": "E2E Test Product",
    "category_id": 1,
    "price": 9.99,
    "image_thumbnail": "https://via.placeholder.com/150",
    "isActive": true
  }
}
script:post-response {
  if (res.status === 201 && res.body.data) {
    bru.setEnvVar("test_product_id", res.body.data.id);
  }
}
tests {
  test("Status is 201", function() {
    expect(res.status).to.equal(201);
  });
  test("Product created successfully", function() {
    expect(res.body.status).to.equal("success");
    expect(res.body.data.name).to.equal("E2E Test Product");
  });
}
